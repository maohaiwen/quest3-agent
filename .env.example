# API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./quest3_agent.db

# Memory Configuration
MEMORY_MAX_TOKENS=1000
MEMORY_VECTOR_DIMENSION=1536

# Log Configuration
LOG_LEVEL=INFO

# LLM Configuration
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Volcengine Configuration (for deep thinking)
VOLCENGINE_API_KEY=xxx
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=deepseek-v3-2-251201
VOLCENGINE_DEFAULT_REASONING_EFFORT=medium
WEB_SEARCH_API_KEY=xxx
