# API Configuration
# Volcengine is the primary LLM provider

# Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./quest3_agent.db

# Memory Configuration
MEMORY_MAX_TOKENS=1000
MEMORY_VECTOR_DIMENSION=1536
MEMORY_MAX_RECENT_MESSAGES=20
MEMORY_SUMMARY_THRESHOLD=30
MEMORY_SUMMARY_KEEP_RECENT=10
MEMORY_AUTO_EXTRACT=true
MEMORY_IMPORTANCE_THRESHOLD=0.3
MEMORY_DECAY_LAMBDA=0.05

# Log Configuration
LOG_LEVEL=INFO
LOG_FORMAT=text

# LLM Configuration
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192

# Volcengine Configuration
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=doubao-seed-2.0-lite-260215
VOLCENGINE_DEFAULT_REASONING_EFFORT=medium

# Web Search Configuration
WEB_SEARCH_API_KEY=your_web_search_api_key_here

# Security Configuration
SECRET_KEY=change-me-in-production-use-a-random-secret
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
TOOL_SANDBOX_DIR=./sandbox_workspace

# MCP Configuration
# MCP_SERVER_URL=http://localhost:8080
